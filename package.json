{
  "name": "typescript-action",
  "version": "0.0.3",
  "private": true,
  "description": "TypeScript template action",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc -b",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "clean": "rm -rf lib dist",
    "lint": "eslint packages/**/*.ts",
    "package-main": "ncc build lib/main/main.js --source-map --license licenses.txt -o dist/main",
    "package-post": "ncc build lib/post/main.js --source-map --license licenses.txt -o dist/post",
    "package": "npm run 'package-main' && npm run 'package-post'",
    "test": "jest",
    "all": "npm run clean && npm run format && npm run lint && npm run build && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/run-notebook.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "step-security",
  "license": "Apache 2.0",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^6.0.0",
    "axios": "1.16.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "@typescript-eslint/parser": "^5.8.1",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^7.32.0",
    "eslint-plugin-github": "^4.3.2",
    "eslint-plugin-jest": "^25.3.2",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "prettier": "2.5.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0"
  }
}
